{
  "id": "com.sidya.fioriform",
  "version": "1.0.0",
  "name": "Fiori Input Form",
  "newInstancePrefix": "FioriForm",
  "properties": {
    "projectId": { "type": "string", "default": "" },
    "customerId": { "type": "string", "default": "" }
  },
  "methods": {
    "setDataSource": {
      "description": "Populates all form fields in one bulk call",
      "parameters": [
        {
          "name": "formData",
          "type": "Selection",
          "description": "All form field values as a single selection object"
        }
      ]
    }
  },
  "events": {},
  "webcomponents": [{
    "kind": "main",
    "tag": "com-sidya-fioriform",
    "url": "https://sokolat.github.io/customwidgets/inputform/custom_input_form.js",
    "integrity": "",
    "ignoreIntegrity": true
  }]
}